# The HUD bundle (app.js) is generated by esbuild, which always writes LF, and
# its TypeScript source is authored LF. Pin both to LF regardless of a checkout's
# core.autocrlf so the CI drift-check (`go generate` + `git diff`) stays byte-
# stable across Windows/Linux and a Windows checkout doesn't rewrite app.js to
# CRLF (which would show spurious diffs against the LF esbuild output).
overlay/frontend/app.js text eol=lf
overlay/frontend/src/app.ts text eol=lf
